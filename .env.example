# ============================================================
# MyHealth Market Lite - Docker Compose 환경 변수
# 이 파일을 .env로 복사하여 값을 설정하세요.
# cp .env.example .env
# ============================================================

# 환경 설정
NODE_ENV=development

# PostgreSQL
POSTGRES_PASSWORD=myhealth_dev_2024

# JWT 인증
JWT_SECRET=your-secure-jwt-secret-key-change-in-production

# OpenAI (AI 건강 코치)
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

# 건강정보 고속도로 테스트베드
MYHEALTHWAY_CLIENT_ID=testbed-client-id
MYHEALTHWAY_CLIENT_SECRET=testbed-client-secret
MYHEALTHWAY_REDIRECT_URI=http://localhost:3001/api/myhealthway/callback

# 프론트엔드 API URL (Docker 내부 통신은 nginx 프록시 사용)
VITE_API_URL=http://localhost:3001
