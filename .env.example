# ============================================================
# MyHealth Market Lite - Docker Compose 환경 변수
# 이 파일을 .env로 복사하여 값을 설정하세요.
# cp .env.example .env
# ============================================================

# 환경 설정
NODE_ENV=development

# PostgreSQL
POSTGRES_PASSWORD=myhealth_dev_2024
# Host port mappings (change if 5432/6379/3001/80 are already in use)
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
SERVER_HOST_PORT=3001
CLIENT_HOST_PORT=80

# JWT 인증
JWT_SECRET=your-secure-jwt-secret-key-change-in-production

# OpenAI (AI 건강 코치)
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

# 건강정보 고속도로 테스트베드
MYHEALTHWAY_CLIENT_ID=testbed-client-id
MYHEALTHWAY_CLIENT_SECRET=testbed-client-secret
MYHEALTHWAY_REDIRECT_URI=http://localhost:3001/api/myhealthway/callback

# 카카오 OAuth (https://developers.kakao.com)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost/api/auth/kakao/callback

# 네이버 OAuth (https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost/api/auth/naver/callback

# 데모 모드 (true면 로그인 없이 데모 사용자로 접근 가능)
DEMO_MODE=true

# 프론트엔드 API URL (Docker 내부 통신은 nginx 프록시 사용)
VITE_API_URL=http://localhost:3001
