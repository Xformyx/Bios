# ============================================================
# MyHealth Market Lite - Docker Compose 환경 변수
# 이 파일을 .env로 복사하여 값을 설정하세요.
# cp .env.example .env
# ============================================================

# 환경 설정
NODE_ENV=production

# PostgreSQL
POSTGRES_PASSWORD=myhealth_dev_2024
POSTGRES_HOST_PORT=5433

# Redis / Server / Client host ports (avoid conflicts with other Docker stacks)
REDIS_HOST_PORT=6380
SERVER_HOST_PORT=3002
CLIENT_HOST_PORT=8088

# JWT 인증
JWT_SECRET=j9Hp1VtqlMNzIi+vZ6zLYQwfYhVLKMokMqz7Gjz9kzg=

# OpenAI (AI 건강 코치)
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

# 건강정보 고속도로 테스트베드
MYHEALTHWAY_CLIENT_ID=testbed-client-id
MYHEALTHWAY_CLIENT_SECRET=testbed-client-secret
MYHEALTHWAY_REDIRECT_URI=http://localhost:3002/api/myhealthway/callback

# 프론트엔드 API URL (Docker 내부 통신은 nginx 프록시 사용)
VITE_API_URL=http://localhost:3002
